# ─────────────────────────────────────────────────────────────────────────────
# Nova Space Intelligence System — Environment Variables
# Copy this file to .env and fill in your values.
# The backend reads these at startup via application.yml placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL 8+) ───────────────────────────────────────────────────────
# The app auto-creates the `nova_space` database on first run
# (createDatabaseIfNotExist=true in the JDBC URL)
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── Redis ────────────────────────────────────────────────────────────────────
# Default: localhost:6379 with no password
# Override these if your Redis instance is remote or password-protected
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (256-bit) for HS256 signing.
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-256-bit-secret-before-deploying

# ── NASA API ─────────────────────────────────────────────────────────────────
# Free key — 1000 requests/hour
# Get yours at: https://api.nasa.gov  (takes 30 seconds)
# Leave as DEMO_KEY for testing (very low rate limit — ~30 req/hr)
NASA_API_KEY=DEMO_KEY

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Required for Nova AI chat — get your key at https://console.anthropic.com
# Pay-per-token; nova uses claude-sonnet-4-20250514, ~512 tokens per response
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── The Space Devs (optional) ────────────────────────────────────────────────
# Provides ISRO + NASA launch data. Works without a key but rate-limited to
# 15 requests/hour on the free tier. Get a free key at https://thespacedevs.com/api
# Leave blank to use the anonymous tier.
SPACE_DEVS_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults cover the Vite dev server; add your production domain here too.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
